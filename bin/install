#!/bin/bash

ln -isTf $(readlink -f tmux) ~/.tmux
ln -isTf $(readlink -f tmux-scroll-copy-mode) ~/.tmux-scroll-copy-mode
ln -isTf $(readlink -f vim) ~/.vim

ln -isf $(readlink -f bash_aliases) ~/.bash_aliases
ln -isf $(readlink -f gemrc) ~/.gemrc
ln -isf $(readlink -f gitconfig) ~/.gitconfig
ln -isf $(readlink -f gitignore) ~/.gitignore
ln -isf $(readlink -f gvimrc) ~/.gvimrc
ln -isf $(readlink -f irbrc) ~/.irbrc
ln -isf $(readlink -f tmux.conf) ~/.tmux.conf
ln -isf $(readlink -f vimrc) ~/.vimrc
ln -isf $(readlink -f zshrc) ~/.zshrc

if [ ! -f "/etc/docker/daemon.json" ]; then
  echo "File '/etc/docker/daemon.json' does not exist, creating."
  mkdir $HOME/docker
  echo "{\"data-root\": \"$HOME/docker\"}" | sudo tee -a "/etc/docker/daemon.json"
else
  echo "Docker daemon.json already exist, skipping."
fi

